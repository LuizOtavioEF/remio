# Copie este arquivo para ".env" e coloque sua chave da API da Anthropic.
# Obtenha a chave em: https://console.anthropic.com/
# IMPORTANTE: o arquivo .env NUNCA deve ser enviado ao GitHub (já está no .gitignore).

ANTHROPIC_API_KEY=coloque-sua-chave-aqui

# Porta do servidor (opcional, padrão 3000)
PORT=3000
